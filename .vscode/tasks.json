{
  // ════════════════════════════════════════════════════════════════════
  // grimoire workspace — VS Code Tasks
  // Ctrl+Shift+P → Tasks: Run Task → choisir la tâche
  // ════════════════════════════════════════════════════════════════════
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}/grimoire-kit",
    "env": {
      "PYTHONDONTWRITEBYTECODE": "1"
    }
  },
  "tasks": [
    // ── Tests ────────────────────────────────────────────────────────
    {
      "label": "bmad: test-all",
      "type": "shell",
      "command": "python3 -m pytest tests/ -q --tb=short -x --ignore=tests/test_background_tasks.py",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "bmad: test-modified",
      "type": "shell",
      "command": "bash -c 'CHANGED=$(git diff --name-only --diff-filter=ACMR HEAD -- \"tests/test_*.py\" | tr \"\\n\" \" \"); if [ -z \"$CHANGED\" ]; then echo \"Aucun test modifié.\"; else python3 -m pytest $CHANGED -q --tb=short -x; fi'",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "bmad: test-file",
      "type": "shell",
      "command": "python3 -m pytest ${relativeFile} -v --tb=short -x",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    // ── Lint ─────────────────────────────────────────────────────────
    {
      "label": "bmad: lint",
      "type": "shell",
      "command": "bash -c 'TARGETS=\"\"; for d in framework/tools tests; do [ -e \"$d\" ] && TARGETS=\"$TARGETS $d\"; done; if [ -z \"$TARGETS\" ]; then echo \"Aucune cible lint trouvée — skip\"; exit 0; fi; python3 -m ruff check $TARGETS --statistics'",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "bmad: lint-fix",
      "type": "shell",
      "command": "bash -c 'TARGETS=\"\"; for d in framework/tools tests; do [ -e \"$d\" ] && TARGETS=\"$TARGETS $d\"; done; if [ -z \"$TARGETS\" ]; then echo \"Aucune cible lint trouvée — skip\"; exit 0; fi; python3 -m ruff check $TARGETS --fix --statistics'",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "bmad: quick-check",
      "type": "shell",
      "command": "bash -c 'echo \"=== LINT ===\"; TARGETS=\"\"; for d in framework/tools tests; do [ -e \"$d\" ] && TARGETS=\"$TARGETS $d\"; done; if [ -z \"$TARGETS\" ]; then echo \"Aucune cible lint trouvée — skip\"; else python3 -m ruff check $TARGETS --statistics -q 2>&1 | tail -5; fi; echo \"\\n=== TESTS (modifiés) ===\"; CHANGED=$(git diff --name-only --diff-filter=ACMR HEAD -- \"tests/test_*.py\" | tr \"\\n\" \" \" ); if [ -z \"$CHANGED\" ]; then echo \"Aucun test modifié — skip\"; else python3 -m pytest $CHANGED -q --tb=line -x; fi'",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    // ── Memory tools ─────────────────────────────────────────────────
    {
      "label": "bmad: memory-lint",
      "type": "shell",
      "command": "python3 framework/tools/memory-lint.py --project-root .",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "bmad: preflight",
      "type": "shell",
      "command": "python3 framework/tools/preflight-check.py --project-root .",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    // ── VS Code environment quickstart (DeepWiki Getting Started) ────
    {
      "label": "grimoire: setup-prereqs",
      "type": "shell",
      "command": "bash -c 'echo \"=== Grimoire — Prérequis environnement (DeepWiki Getting Started) ===\"; PLATFORM=$(uname -s); echo \"Plateforme : $PLATFORM\"; echo \"\"; if [ \"$PLATFORM\" = \"Linux\" ]; then echo \"[Git]\"; command -v git >/dev/null 2>&1 && echo \"  ✅ $(git --version)\" || echo \"  ❌ git absent\"; echo \"\"; echo \"[Node.js]\"; if command -v node >/dev/null 2>&1; then NODEV=$(node --version); NODEARCH=$(node -p process.arch 2>/dev/null || echo unknown); echo \"  ✅ $NODEV ($NODEARCH)\"; [ \"$NODEARCH\" = \"x64\" ] || [ \"$NODEARCH\" = \"arm64\" ] || echo \"  ⚠️  Architecture non recommandée par VS Code (attendu: x64/arm64)\"; else echo \"  ❌ Absent — curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash - && sudo apt-get install -y nodejs\"; fi; echo \"\"; echo \"[Python (node-gyp)]\"; command -v python >/dev/null 2>&1 && echo \"  ✅ $(python --version 2>&1)\" || echo \"  ❌ commande python absente — installer python-is-python3\"; echo \"\"; echo \"[Build tools]\"; for t in g++ make pkg-config; do command -v $t >/dev/null 2>&1 && echo \"  ✅ $t\" || echo \"  ❌ $t\"; done; echo \"\"; echo \"[Bibliothèques natives VS Code]\"; if command -v dpkg >/dev/null 2>&1; then MISSING=\"\"; for pkg in libx11-dev libxkbfile-dev libsecret-1-dev libkrb5-dev; do dpkg -l $pkg 2>/dev/null | grep -q \"^ii\" && echo \"  ✅ $pkg\" || { echo \"  ❌ $pkg\"; MISSING=\"$MISSING $pkg\"; }; done; [ -n \"$MISSING\" ] && { echo \"\"; echo \"  → sudo apt-get install build-essential g++$MISSING python-is-python3\"; }; elif command -v pkg-config >/dev/null 2>&1; then MISSING=\"\"; for pc in x11 xkbfile libsecret-1 krb5; do pkg-config --exists $pc && echo \"  ✅ $pc (pkg-config)\" || { echo \"  ❌ $pc (pkg-config)\"; MISSING=\"$MISSING $pc\"; }; done; [ -n \"$MISSING\" ] && echo \"  → Installer paquets devel correspondants (ex: libX11-devel/libxkbfile-devel/libsecret-devel/krb5-devel)\"; else echo \"  ⚠️  pkg-config absent — impossible de vérifier les libs natives\"; fi; echo \"\"; echo \"[inotify watch limit]\"; WATCHES=$(cat /proc/sys/fs/inotify/max_user_watches 2>/dev/null || echo 0); if [ \"$WATCHES\" -ge 524288 ]; then echo \"  ✅ max_user_watches=$WATCHES\"; else echo \"  ❌ max_user_watches=$WATCHES (recommandé >= 524288)\"; echo \"  → echo fs.inotify.max_user_watches=524288 | sudo tee -a /etc/sysctl.conf && sudo sysctl -p\"; fi; echo \"\"; echo \"[WSL]\"; if grep -qi microsoft /proc/version 2>/dev/null; then grep -qi wsl2 /proc/version 2>/dev/null && echo \"  ✅ WSL2\" || echo \"  ❌ WSL1 détecté (non supporté pour builds VS Code)\"; else echo \"  ✅ Non-WSL\"; fi; if [ -d .devcontainer ]; then echo \"\"; echo \"[Dev Container]\"; command -v docker >/dev/null 2>&1 && echo \"  ✅ docker disponible\" || echo \"  ⚠️  .devcontainer présent mais docker absent (utiliser Codespaces ou installer Docker)\"; fi; elif [ \"$PLATFORM\" = \"Darwin\" ]; then echo \"[macOS toolchain]\"; xcode-select -p >/dev/null 2>&1 && echo \"  ✅ Xcode CLI Tools\" || echo \"  ❌ Absent — xcode-select --install\"; if command -v node >/dev/null 2>&1; then NODEV=$(node --version); NODEARCH=$(node -p process.arch 2>/dev/null || echo unknown); echo \"  ✅ Node.js $NODEV ($NODEARCH)\"; [ \"$NODEARCH\" = \"x64\" ] || [ \"$NODEARCH\" = \"arm64\" ] || echo \"  ⚠️  Architecture non recommandée (attendu: x64/arm64)\"; else echo \"  ❌ Node.js absent\"; fi; command -v python >/dev/null 2>&1 && echo \"  ✅ $(python --version 2>&1)\" || echo \"  ❌ commande python absente\"; fi; echo \"\"'",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "grimoire: vscode-diagnostics",
      "type": "shell",
      "command": "bash -c 'OUT=\"${workspaceFolder}/_bmad-output/test-artifacts/vscode\"; mkdir -p \"$OUT\"; TS=$(date +%Y%m%d-%H%M%S); if command -v code >/dev/null 2>&1; then code --status > \"$OUT/code-status-$TS.txt\" 2>&1 || true; code --verbose --status > \"$OUT/code-verbose-status-$TS.txt\" 2>&1 || true; echo \"Diagnostics sauvegardes dans $OUT\"; else echo \"Commande code indisponible dans ce shell\"; fi'",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "grimoire: vscode-performance-bundle",
      "type": "shell",
      "command": "bash -c 'OUT=\"${workspaceFolder}/_bmad-output/test-artifacts/vscode\"; mkdir -p \"$OUT\"; TS=$(date +%Y%m%d-%H%M%S); B=\"$OUT/perf-bundle-$TS\"; mkdir -p \"$B\"; if command -v code >/dev/null 2>&1; then code --status > \"$B/code-status.txt\" 2>&1 || true; code --verbose --status > \"$B/code-verbose-status.txt\" 2>&1 || true; printf \"# VS Code Performance Bundle (%s)\\n\\n\" \"$TS\" > \"$B/README.md\"; printf \"## Captures auto\\n- code-status.txt\\n- code-verbose-status.txt\\n\\n\" >> \"$B/README.md\"; printf \"## Etapes manuelles recommandees (DeepWiki)\\n1. Help > Open Process Explorer\\n2. F1 > Developer: Show Running Extensions\\n3. F1 > Startup Performance\\n4. Help > Start Extension Bisect (si suspicion extension)\\n5. Help > Report Issue (Performance Issue)\\n\" >> \"$B/README.md\"; echo \"Bundle cree: $B\"; else echo \"Commande code indisponible dans ce shell\"; fi'",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    // ── Dynamic Artifact Cleanup ─────────────────────────────────────
    {
      "label": "bmad: cleanup-dynamic-artifacts",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.github/hooks/scripts/bmad-cleanup-dynamic-artifacts.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    // ── Documentation auto-sync ──────────────────────────────────────
    {
      "label": "bmad: auto-doc-check",
      "type": "shell",
      "command": "python3 framework/tools/auto-doc.py --project-root . check",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "bmad: auto-doc-sync",
      "type": "shell",
      "command": "python3 framework/tools/auto-doc.py --project-root . sync",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    // ── Maintenance — empêcher l'accumulation d'objets git loose ─────
    {
      "label": "bmad: git-gc",
      "type": "shell",
      "command": "git gc && cd grimoire-kit && git gc",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    // ── Configuration utilisateur ────────────────────────────────────
    {
      "label": "grimoire: setup",
      "type": "shell",
      "command": "bash grimoire.sh setup --sync",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "grimoire: setup-check",
      "type": "shell",
      "command": "bash grimoire.sh setup --check",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "grimoire: install-git-hooks",
      "type": "shell",
      "command": "bash grimoire-init.sh hooks --install",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "grimoire: setup-interactive",
      "type": "shell",
      "command": "bash grimoire.sh setup",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    // ── Skill Validator ──────────────────────────────────────────────
    {
      "label": "bmad: validate-skills",
      "type": "shell",
      "command": "python3 framework/tools/skill-validator.py --project-root .",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    }
  ]
}