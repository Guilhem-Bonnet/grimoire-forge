# ═══════════════════════════════════════════════════════════════════════════════
# bmad-custom (meta-projet) — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# Le produit a son propre repo git — on l'exclut ici
bmad-custom-kit/

# Python
__pycache__/
*.py[cod]
*$py.class

# IDE personnel
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# BMAD runtime (mémoire, cache)
_bmad/_memory/*.json
_bmad/_memory/qdrant_cache/
qdrant_data/

# pytest
.pytest_cache/
.ruff_cache/
