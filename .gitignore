# ═══════════════════════════════════════════════════════════════════════════════
# grimoire (meta-projet) — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# Le produit a son propre repo git — on l'exclut ici
grimoire-kit/

# Python
__pycache__/
*.py[cod]
*$py.class

# IDE personnel
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# BMAD runtime (mémoire, cache)
_bmad/_memory/*.json
_bmad/_memory/*.jsonl
_bmad/_memory/qdrant_cache/
qdrant_data/

# BMAD output runtime (logs, dashboards, vector DB)
_bmad-output/.agent-graph.yaml
_bmad-output/.event-log.jsonl
_bmad-output/.qdrant_data/
_bmad-output/.router-stats.jsonl
_bmad-output/.workers/
_bmad-output/observatory.html
_bmad-output/BMAD_TRACE.md
_bmad-output/test-artifacts/

# Grimoire runtime (mémoire, cache)
_grimoire/_memory/*.json
_grimoire/_memory/*.jsonl
_grimoire/_memory/qdrant_data/
_grimoire/_memory/backends/__pycache__/

# Grimoire output runtime
_grimoire-output/

# pytest
.pytest_cache/
.ruff_cache/
